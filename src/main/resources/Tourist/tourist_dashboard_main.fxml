<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Tourist.TouristDashboardMainController">
    <!-- Top Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="🏔️" style="-fx-font-size: 24; -fx-text-fill: #e53e3e;" />
                <Label text="GHUMGHAM" textFill="#e53e3e">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" prefWidth="300.0" promptText="Search for tourist and guides" style="-fx-background-radius: 20; -fx-padding: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 20;" />
            <Button fx:id="notificationButton" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-font-size: 16;" text="🔔" />
            <Button fx:id="settingsButton" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-font-size: 16;" text="⚙️" />
            <ComboBox fx:id="languageCombo" prefWidth="100.0" promptText="English" style="-fx-background-radius: 5;" />
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <Label fx:id="userAvatar" text="A" style="-fx-background-color: #666666; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8; -fx-font-weight: bold;" />
                <Label fx:id="userNameLabel" text="Angel">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
            </HBox>
        </HBox>
    </top>

    <!-- Left Sidebar -->
    <left>
        <VBox prefWidth="180.0" spacing="5.0" style="-fx-background-color: #f8f9fa; -fx-padding: 20;">
            <Button fx:id="dashboardBtn" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#showDashboard" prefWidth="140.0" style="-fx-background-color: #e53e3e; -fx-text-fill: white; -fx-padding: 12; -fx-font-size: 14; -fx-background-radius: 8;" text="🏠 Dashboard" />
            <Button fx:id="profileBtn" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#showProfile" prefWidth="140.0" style="-fx-background-color: transparent; -fx-padding: 12; -fx-font-size: 14;" text="👤 My profile" />
            <Button fx:id="exploreBtn" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#showExplore" prefWidth="140.0" style="-fx-background-color: transparent; -fx-padding: 12; -fx-font-size: 14;" text="📍 Explore" />
            <Button fx:id="bookingsBtn" alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#showBookings" prefWidth="140.0" style="-fx-background-color: transparent; -fx-padding: 12; -fx-font-size: 14;" text="🏠 Bookings" />
        </VBox>
    </left>

    <!-- Main Content Area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #f5f5f5;">
            <!-- Content will be loaded here -->
        </StackPane>
    </center>
</BorderPane>
