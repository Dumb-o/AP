<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Tourist.TouristDashboardContentController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Welcome Header -->
    <VBox spacing="10.0" style="-fx-background-color: linear-gradient(to right, #4CAF50, #81C784); -fx-background-radius: 15; -fx-padding: 30;">
        <Label fx:id="welcomeLabel" text="Namaste Tourist," textFill="white">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <Label text="Ready for your next adventure in the Himalayas?" textFill="white">
            <font>
                <Font size="16.0" />
            </font>
        </Label>
        <HBox spacing="30.0" />
    </VBox>

    <!-- Content Row -->
    <HBox spacing="20.0" VBox.vgrow="ALWAYS">
        <!-- Upcoming Booked Trek Section -->
        <VBox fx:id="upcomingTrekContainer" spacing="15.0" style="-fx-background-color: linear-gradient(to bottom, #E3F2FD, #BBDEFB); -fx-background-radius: 15; -fx-padding: 25;" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
            <Label text="Your Next Adventure" textFill="#1976D2">
                <font>
                    <Font name="System Bold" size="14.0" />
                </font>
            </Label>
            <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label style="-fx-font-size: 20;" text="🏔️" />
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label fx:id="trekNameLabel" text="No upcoming trek" textFill="#333333">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <Label fx:id="trekLocationLabel" text="Location not available" textFill="#666666">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </VBox>
                    <Label fx:id="difficultyLabel" style="-fx-background-color: #9E9E9E; -fx-background-radius: 15; -fx-padding: 5 10;" text="N/A" textFill="white">
                        <font>
                            <Font size="10.0" />
                        </font>
                    </Label>
                </HBox>
                <Label fx:id="trekDescriptionLabel" text="No trek information available." textFill="#666666" wrapText="true">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <Label fx:id="trekWarningLabel" text="⚠️ Book your first trek to see details here" textFill="#F44336">
                        <font>
                            <Font size="11.0" />
                        </font>
                    </Label>
                </HBox>
            </VBox>
        </VBox>
    </HBox>

    <!-- Statistics Cards -->
    <HBox prefHeight="172.0" prefWidth="557.0" spacing="20.0">
        <VBox prefHeight="172.0" prefWidth="271.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-border-color: #e0e0e0; -fx-border-radius: 15;" HBox.hgrow="ALWAYS">
            <Label text="Active bookings" textFill="#666666">
                <font>
                    <Font size="14.0" />
                </font>
            </Label>
            <Label fx:id="activeTripsLabel" text="0" textFill="#333333">
                <font>
                    <Font name="System Bold" size="32.0" />
                </font>
            </Label>
        </VBox>

        <!-- Calendar -->
        <VBox prefHeight="172.0" prefWidth="338.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25; -fx-border-color: #e0e0e0; -fx-border-radius: 15;" HBox.hgrow="ALWAYS">
            <Label text="CALENDAR" textFill="#333333">
                <font>
                    <Font name="System Bold" size="14.0" />
                </font>
            </Label>
            <!-- Simple Calendar Grid -->
            <GridPane fx:id="calendarGrid" hgap="5.0" vgap="5.0">
                <!-- Calendar will be populated by controller -->
            </GridPane>
        </VBox>
    </HBox>
</VBox>
