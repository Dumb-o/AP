<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Tourist.TouristBookingController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header -->
    <Label text="BOOKINGS" textFill="#333333">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <!-- Filter and Actions Row -->
    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- Bookings Table -->
    <TableView fx:id="bookingsTable" prefHeight="400.0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 10; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="touristColumn" prefWidth="150.0" style="-fx-alignment: CENTER-LEFT;" text="Tourist" />
            <TableColumn fx:id="guideColumn" prefWidth="150.0" style="-fx-alignment: CENTER-LEFT;" text="Guide" />
            <TableColumn fx:id="attractionColumn" prefWidth="200.0" style="-fx-alignment: CENTER-LEFT;" text="Attraction" />
            <TableColumn fx:id="dateColumn" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Date" />
        </columns>

        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- Action Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="15.0" />

    <!-- Empty State (initially hidden) -->
    <VBox fx:id="emptyStateContainer" alignment="CENTER" spacing="15.0" style="-fx-padding: 50;" visible="false">
        <Label style="-fx-font-size: 48px;" text="📋" />
        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #666666;" text="No bookings found" />
        <Label style="-fx-font-size: 14px; -fx-text-fill: #999999; -fx-text-alignment: center;" text="You haven't made any trek bookings yet. Explore our treks to make your first booking!" wrapText="true" />
        <Button fx:id="exploreButton" style="-fx-background-color: #e53e3e; -fx-text-fill: white; -fx-padding: 12 24; -fx-background-radius: 8; -fx-cursor: hand;" text="Explore Treks" />
    </VBox>
</VBox>
