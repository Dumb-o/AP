<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Admin.DashboardContentController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <!-- Welcome, Section -->
    <VBox spacing="10.0">
        <Label fx:id="welcomeLabel" text="Namaste Admin," textFill="#333333">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <Label text="Here's what's happening with your trekking business today." textFill="#666666">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
    </VBox>

    <!-- Statistics Cards -->
    <HBox spacing="20.0">
        <!-- Total Tourists Card -->
        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: #e0e0e0; -fx-border-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label fx:id="totalTouristsLabel" text="0" textFill="#333333">
                <font>
                    <Font name="System Bold" size="28.0" />
                </font>
            </Label>
            <Label text="Total Tourists" textFill="#666666">
                <font>
                    <Font size="14.0" />
                </font>
            </Label>
        </VBox>

        <!-- Active Guides Card -->
        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: #e0e0e0; -fx-border-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label fx:id="activeGuidesLabel" text="0" textFill="#333333">
                <font>
                    <Font name="System Bold" size="28.0" />
                </font>
            </Label>
            <Label text="Active Guides" textFill="#666666">
                <font>
                    <Font size="14.0" />
                </font>
            </Label>
        </VBox>

        <!-- Total Emergencies Card -->
        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: #e0e0e0; -fx-border-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label fx:id="totalEmergenciesLabel" text="0" textFill="#e53e3e">
                <font>
                    <Font name="System Bold" size="28.0" />
                </font>
            </Label>
            <Label text="Total Emergencies" textFill="#666666">
                <font>
                    <Font size="14.0" />
                </font>
            </Label>
        </VBox>
    </HBox>

    <!-- Main Content Row -->
    <HBox spacing="20.0" VBox.vgrow="ALWAYS">
        <!-- Booking Trends Chart -->
        <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: #e0e0e0; -fx-border-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
            <Label text="Booking Trends by Attraction" textFill="#333333">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
            </Label>

            <BarChart fx:id="bookingTrendsChart" prefHeight="300.0" VBox.vgrow="ALWAYS">
                <xAxis>
                    <CategoryAxis side="BOTTOM" />
                </xAxis>
                <yAxis>
                    <NumberAxis side="LEFT" />
                </yAxis>
            </BarChart>
        </VBox>

        <!-- Recent Activity -->
        <VBox prefWidth="300.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: #e0e0e0; -fx-border-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
            <Label text="Recent Activity" textFill="#333333">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
            </Label>

            <ScrollPane fitToWidth="true" prefHeight="300.0" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <VBox fx:id="activityList" spacing="10.0" />
            </ScrollPane>
        </VBox>
    </HBox>
</VBox>
